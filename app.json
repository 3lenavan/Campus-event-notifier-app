{
  "expo": {
    "name": "BuzzUp",
    "slug": "campus-event-notifier-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/buzzup-app-icon.png",
    "scheme": "campuseventnotifierapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7C928",
        "foregroundImage": "./assets/images/buzzup-app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/buzzup-app-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9E8",
          "image": "./assets/images/buzzup-app-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#2A1A0E",
            "image": "./assets/images/buzzup-app-icon.png"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload event images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F7C928"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "The app needs access to your camera to scan event check-in codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
